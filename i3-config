#define mod key
set $mod Mod4

#window config
new_window pixel 1
font pango:monospace 8
#kill a window 
bindsym $mod+Shift+q kill
#window focus changes
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right
#window move from focus 
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right
#full screen focused window toggle
bindsym $mod+f fullscreen toggle
#binds to minimise apps
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show
#tile border colors
client.focused #FFFFFF #FFFFFF #000000 #FFFFFF 
client.unfocused #444444 #444444 #444444 #888888

#lock on timeout old command 
#exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork
#install i3lock-color new command
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock-color --blur 5x5 --indicator

#initalise network 
exec --no-startup-id nm-applet

#terminal configirations
#start a terminal
bindsym $mod+Return exec kitty 
#reload i3 config file
bindsym $mod+Shift+r restart
#binds for app libary 
bindsym $mod+a exec --no-startup-id rofi -show drun

###custom commands 

#volume controls with an interface running with a custom python script 
bindsym XF86AudioLowerVolume exec --no-startup-id wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%- && dunstify -a "Volume" -t 1000 -r 9910 -h int:value:"$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print int($2 * 100)}')" "Volume: $(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print int($2 * 100)}')%"
bindsym XF86AudioRaiseVolume exec --no-startup-id wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+ && dunstify -a "Volume" -t 1000 -r 9910 -h int:value:"$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print int($2 * 100)}')" "Volume: $(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print int($2 * 100)}')%"

#brightness controls no interface running with custom c script 
bindsym XF86MonBrightnessUp exec --no-startup-id brightness_tool +25
bindcode 232 exec --no-startup-id brightness_tool -25

#wallpaper 
#select wallpaper from local files
exec_always --no-startup-id feh --bg-fill --randomize /home/asheyash/Downloads/wallpapers/
#run picom for transparancy
exec_always --no-startup-id killall picom; sleep 2 && /usr/bin/picom -b
